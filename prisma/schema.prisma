// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  ADMINISTRATOR
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  theme         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  teams        Team[]
  competitions Competition[]
  competitionPosts CompetitionPost[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Sport {
  id          String   @id @default(cuid())
  name        String   @unique
  icon        String?
  description String?
  config      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teams        Team[]
  positions    Position[]
  competitions Competition[]
  eventTypes   EventType[]
}

model EventType {
  id           String   @id @default(cuid())
  sportId      String
  name         String
  labelCs      String
  labelEn      String
  value        Int?
  affectsScore Boolean  @default(true)
  color        String?
  icon         String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sport Sport @relation(fields: [sportId], references: [id], onDelete: Cascade)

  @@unique([sportId, name])
}

model Position {
  id       String  @id @default(cuid())
  name     String
  labelCs  String  @default("")
  labelEn  String  @default("")
  sportId  String

  sport   Sport    @relation(fields: [sportId], references: [id], onDelete: Cascade)
  players Player[]

  @@unique([name, sportId])
}

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  logoUrl     String?
  ownerId     String
  sportId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner        User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sport        Sport?            @relation(fields: [sportId], references: [id], onDelete: SetNull)
  players      Player[]
  competitions CompetitionTeam[]
  homeMatches  Match[]           @relation("HomeMatches")
  awayMatches  Match[]           @relation("AwayMatches")
}

enum CompetitionType {
  LEAGUE
  CUP
  TOURNAMENT
}

enum CompetitionStatus {
  DRAFT
  ACTIVE
  FINISHED
}

enum MatchStatus {
  SCHEDULED
  PLAYED
  CANCELLED
}

model Competition {
  id           String            @id @default(cuid())
  name         String
  description  String?
  type         CompetitionType
  status       CompetitionStatus @default(DRAFT)
  isPublic     Boolean           @default(true)
  sportId      String?
  organizerId  String
  startDate      DateTime?
  endDate        DateTime?
  periodCount    Int?
  periodDuration Int?
  maxTeams       Int?
  allowWaitlist  Boolean           @default(false)

  // CUP advancement configuration
  cupAdvancementPreset    String?  // e.g. "WINNERS_ONLY", "TOP2_CROSS", "TOP2_STRAIGHT", "TOP2_BEST_3RD", "TOP3_ALL"
  cupTeamsPerGroup        Int?     // 1, 2, or 3
  cupThirdPlaceAdvance    Int?     // number of best 3rd places advancing (0, 1, 2, 4)
  cupCustomPairings       String?  // JSON serialized custom pairings (for CUSTOM preset)
  thirdPlaceMatch  Boolean  @default(false)  // generate 3rd place match for TOURNAMENT/CUP
  logoUrl          String?

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  sport      Sport?            @relation(fields: [sportId], references: [id], onDelete: SetNull)
  organizer  User              @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  teams      CompetitionTeam[]
  matches    Match[]
  awards     CompetitionAward[]
  posts      CompetitionPost[]
}

model CompetitionPost {
  id            String   @id @default(cuid())
  competitionId String
  authorId      String
  body          String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  author      User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model CompetitionTeam {
  id            String   @id @default(cuid())
  competitionId String
  teamId        String?
  guestName     String?
  rosterToken   String?  @unique @default(cuid())
  isWaitlisted  Boolean  @default(false)
  joinedAt      DateTime @default(now())

  competition   Competition   @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  team          Team?         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  guestPlayers  GuestPlayer[]

  @@unique([competitionId, teamId])
}

model GuestPlayer {
  id               String  @id @default(cuid())
  competitionTeamId String
  name             String
  number           Int?

  competitionTeam CompetitionTeam @relation(fields: [competitionTeamId], references: [id], onDelete: Cascade)
  matchLineups    MatchPlayer[]
}

model Match {
  id             String      @id @default(cuid())
  competitionId  String
  homeTeamId     String?
  awayTeamId     String?
  homeTeamName   String?
  awayTeamName   String?
  bracketPos     Int?
  homeScore      Int?
  awayScore      Int?
  scheduledAt    DateTime?
  playedAt       DateTime?
  status         MatchStatus @default(SCHEDULED)
  round          Int?
  note           String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  matchState    String?
  period        Int?
  startedAt     DateTime?
  periodOffset  Int?

  competition   Competition       @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  homeTeam      Team?             @relation("HomeMatches", fields: [homeTeamId], references: [id])
  awayTeam      Team?             @relation("AwayMatches", fields: [awayTeamId], references: [id])
  events        MatchEvent[]
  refereeToken  MatchRefereeToken?
  matchPlayers  MatchPlayer[]
  lineupTokens  LineupToken[]
}

model MatchEvent {
  id         String   @id @default(cuid())
  matchId    String
  type       String
  minute     Int?
  addedTime  Int?
  teamSide   String
  playerName  String?
  player2Name String?
  createdAt   DateTime @default(now())

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model MatchRefereeToken {
  id        String    @id @default(cuid())
  matchId   String    @unique
  token     String    @unique @default(cuid())
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Player {
  id         String  @id @default(cuid())
  number     Int?
  name       String
  teamId     String
  positionId String?

  team         Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  position     Position?      @relation(fields: [positionId], references: [id], onDelete: SetNull)
  awards       CompetitionAward[]
  matchLineups MatchPlayer[]
}

enum LineupSlot {
  STARTER
  SUBSTITUTE
}

model LineupToken {
  id        String    @id @default(cuid())
  matchId   String
  teamSide  String
  token     String    @unique @default(cuid())
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, teamSide])
}

model MatchPlayer {
  id            String     @id @default(cuid())
  matchId       String
  playerId      String?
  guestPlayerId String?
  teamSide      String
  slot          LineupSlot @default(STARTER)
  shirtNumber   Int?

  match       Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player      Player?      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  guestPlayer GuestPlayer? @relation(fields: [guestPlayerId], references: [id], onDelete: Cascade)
}

model CompetitionAward {
  id            String   @id @default(cuid())
  competitionId String
  title         String
  recipientName String
  icon          String?  // emoji or predefined icon key
  playerId      String?  // optional — link to a Player record
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  player      Player?     @relation(fields: [playerId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     String
  entity     String
  entityId   String?
  detail     String?
  createdAt  DateTime @default(now())
}
